            raise Exception(f"更新失败: {result.get('message', '未知错误')}")
        
        self.update_count += 1
        logger.info(f"更新成功，记录ID: {target_id}, 累计更新: {self.update_count}")
        
        return result
    
    def _perform_update(self, data: Dict[str, Any], target_id: str) -> Dict[str, Any]:
        """
