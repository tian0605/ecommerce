    print(f"测试2 - 括号状态：{result2['bracket_status']}")
    print(f"测试2 - 语法有效：{result2['syntax_valid']}")
    
    return result['syntax_valid'] or result2['syntax_valid']

if __name__ == "__main__":
    # 运行测试
    test_fix()
    print("\n修复工具已就绪，可使用 fix_syntax_error() 函数修复代码")
