    assert "不能为空" in empty_result["error"]
    
    # 测试内存存储
    memory_result = fix_store_operation(test_data, store_type="memory")
    assert validate_store_result(memory_result), "内存存储应该成功"
    
    print("所有测试通过！")
    return True


if __name__ == "__main__":
    test_fix()
