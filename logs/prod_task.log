        "task_id": "FIX-TC-FLOW-001-011",
        "datetime": "2026-03-27 00",
        "status": "failed"
    }
    processed = process_task_datetime(task_info)
    assert processed["datetime"] == "2026-03-27 00:00:00"
    
    print("所有测试通过！")
    return True


if __name__ == "__main__":
    test_fix()
