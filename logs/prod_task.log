    if data is None:
        data = {
            "product_id": "TEST-001",
            "name": "测试商品",
            "price": 99.99,
            "stock": 100
        }
    
    result = {
        "success": False,
        "message": "",
        "data": None
    }
    
    try:
        # 执行存储操作
        success = store_data(data, store_type="memory")
        
        if success:
            result["success"] = True
            result["message"] = "存储操作成功完成"
            result["data"] = data
        else:
            result["message"] = "存储操作返回失败"
            
    except StoreError as e:
        result["message"] = f"存储错误: {str(e)}"
    except Exception as e:
        result["message"] = f"未知错误: {str(e)}"
    
    return result


# 测试验证
